{
  "name": "@zenky/storefront-api",
  "version": "0.0.0-development",
  "description": "Zenky Storefront API SDK",
  "author": "Zenky <tech@zenky.io>",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "main": "./dist/zenky-storefront-api.umd.s",
  "module": "./dist/zenky-storefront-api.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/zenky-storefront-api.es.js",
      "require": "./dist/zenky-storefront-api.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "types": "dts-bundle-generator --out-file ./dist/index.d.ts ./src/index.ts",
    "docs:build": "node scripts/generate-docs-html.mjs"
  },
  "devDependencies": {
    "@types/node": "^18.8.0",
    "@types/postmate": "^1.5.3",
    "cross-fetch": "^3.1.6",
    "dts-bundle-generator": "^8.0.1",
    "marked": "^17.0.3",
    "typescript": "^5.0.2",
    "vite": "^4.3.9",
    "vite-plugin-dts": "^2.3.0"
  },
  "dependencies": {
    "postmate": "^1.5.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenky/ts-storefront-api.git"
  }
}
